<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="newo_conversation_view_list" model="ir.ui.view">
        <field name="name">newo.conversation.list</field>
        <field name="model">newo.conversation</field>
        <field name="arch" type="xml">
            <list string="Conversations">
                <field name="started_at"/>
                <field name="channel"/>
                <field name="intent"/>
                <field name="partner_id"/>
                <field name="lead_id"/>
                <field name="external_id"/>
            </list>
        </field>
    </record>

    <record id="newo_conversation_view_form" model="ir.ui.view">
        <field name="name">newo.conversation.form</field>
        <field name="model">newo.conversation</field>
        <field name="arch" type="xml">
            <form string="Conversation">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="external_id" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="started_at"/>
                            <field name="ended_at"/>
                            <field name="channel"/>
                            <field name="intent"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                            <field name="lead_id"/>
                            <field name="recording_url" widget="url"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Summary" name="summary">
                            <field name="summary"/>
                        </page>
                        <page string="Transcript" name="transcript">
                            <field name="transcript"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="newo_conversation_action" model="ir.actions.act_window">
        <field name="name">Conversations</field>
        <field name="res_model">newo.conversation</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="newo_root_menu" name="Newo AI" sequence="80"/>
    <menuitem id="newo_conversations_menu" name="Conversations" parent="newo_root_menu" action="newo_conversation_action" sequence="10"/>
</odoo>
